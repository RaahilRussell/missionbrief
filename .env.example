# Copy to .env (the seed + dev server read from .env).
DATABASE_URL="file:./dev.db"

# --- Optional LLM mode ---------------------------------------------------
# The demo runs fully in deterministic mode with NO keys required.
# Set REPORT_ENGINE to opt into an LLM for narrative polish.
#   deterministic (default) | openai | ollama
REPORT_ENGINE="deterministic"

# Only used when REPORT_ENGINE="openai"
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"

# Only used when REPORT_ENGINE="ollama" (local model server)
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3.1"
